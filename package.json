{
  "name": "kanbantool-mcp",
  "version": "1.0.0",
  "description": "MCP server for KanbanTool.com — manage boards, tasks, swimlanes and workflow states via AI assistants",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc --noEmit false",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "biome lint src",
    "format": "biome format src --write",
    "check": "biome check src",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "kanbantool",
    "kanban",
    "ai",
    "claude"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
